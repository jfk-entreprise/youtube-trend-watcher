# YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here
# Optional: Slack webhook for notifications
SLACK_WEBHOOK_URL=

# Optional: region/language targeting
YOUTUBE_REGION_CODE=FR
YOUTUBE_LANGUAGE=fr

# Supabase (Sprint 6) — Settings > API dans le Dashboard Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Groq
GROQ_API_KEY=your_groq_api_key_here

GROQ_MODEL_SCRIPT=openai/gpt-oss-120b
GROQ_MODEL_PROMPT=llama-3.3-70b-versatile

DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Modele DeepSeek utilise systematiquement par LLMScriptGenerator quand
# aucun modele n'est explicitement demande (Sprint 24, fiabilise Sprint 27).
# deepseek-reasoner s'est revele peu fiable en json_mode strict pour une
# sortie structuree volumineuse (le raisonnement interne peut consommer tout
# le budget max_tokens avant meme d'ecrire le JSON, laissant une reponse
# vide) ; deepseek-chat est plus fiable pour ce contrat.
DEEPSEEK_MODEL_SCRIPT=deepseek-chat

# Modele DeepSeek utilise systematiquement par LLMImageGenerator quand aucun
# modele n'est explicitement demande. deepseek-reasoner est reserve aux
# taches de raisonnement longues (evaluation, reecriture) ; deepseek-chat
# est plus fiable en json_mode strict pour les prompts d'image (Sprint 24.5)
DEEPSEEK_IMAGE_MODEL=deepseek-chat

# Modele DeepSeek utilise systematiquement par LLMAnimationGenerator quand
# aucun modele n'est explicitement demande (Sprint 25). deepseek-chat est
# plus fiable en json_mode strict que deepseek-reasoner pour ce contrat.
DEEPSEEK_ANIMATION_MODEL=deepseek-chat

# Modele DeepSeek utilise systematiquement par VisualDirector quand aucun
# modele n'est explicitement demande (Sprint 26).
DEEPSEEK_VISUAL_DIRECTOR_MODEL=deepseek-chat

# Stockage des packages de production (Sprint 30) — SupabaseStorageUploader
# (src/supabase_storage_uploader.py). Remplace Google Drive (un compte de
# service Google n'a aucun quota de stockage propre — voir historique du
# projet, Sprint 29.2). Reutilise SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY
# ci-dessus : aucune variable supplementaire a configurer.
#
# Procedure :
#   1. Dashboard Supabase > Storage > New bucket > nommer le bucket "production".
#   2. Rien d'autre a faire : la cle service_role a deja tous les droits necessaires.
# Sans SUPABASE_URL/SUPABASE_SERVICE_ROLE_KEY (ou si le bucket "production"
# n'existe pas), le pipeline utilise NoOpStorageUploader (aucun envoi reel,
# le package reste disponible uniquement en local).

# Telegram (Sprint 29) — NotificationService (src/notification_service.py)
# Envoie automatiquement le resume de production quotidien via un bot Telegram.
#
# Procedure :
#   1. Parler a @BotFather sur Telegram, envoyer /newbot et suivre les etapes —
#      recuperer le token du bot (format 123456789:ABC-...).
#   2. Demarrer une conversation avec le bot (ou l'ajouter a un groupe/canal).
#   3. Recuperer le chat_id : envoyer un message au bot puis ouvrir
#      https://api.telegram.org/bot<TOKEN>/getUpdates dans un navigateur —
#      le champ "chat":{"id": ...} contient le chat_id (nombre, parfois negatif
#      pour un groupe).
# Sans ces deux variables, le pipeline utilise LoggingNotificationService
# (le resume est uniquement journalise dans les logs, jamais envoye).
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here